<file path="templates/socialaccount/authentication_error.html">
{% load i18n %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Google Login – Debug Info</title>
  <style>
    body { font-family: monospace; background: #faf7f2; padding: 40px; color: #1a1a1a; }
    h2 { color: #c0392b; }
    .box { background:#fff; border:1px solid #e0d8cc; border-radius:10px; padding:24px;
           max-width:820px; margin:0 auto; box-shadow:0 4px 16px rgba(0,0,0,.07); }
    code { display:block; background:#f4f0e8; padding:14px; border-radius:6px;
           white-space:pre-wrap; word-break:break-all; font-size:.85rem; }
    .step { margin-top:18px; }
    .step strong { color:#1f8a70; }
    a { color:#1f8a70; }
  </style>
</head>
<body>
<div class="box">
  <h2>&#9888; Google Login Failed — Debug Mode</h2>

  {% if exception %}
  <div class="step">
    <strong>Exception caught by allauth:</strong>
    <code>{{ exception }}</code>
  </div>
  {% endif %}

  <div class="step">
    <strong>What to do RIGHT NOW:</strong><br>
    Look at the Django <b>runserver terminal</b> — the full Python traceback is printed
    there with the exact line that failed. Copy and paste it.
  </div>

  <div class="step">
    <strong>Quick checklist while you check the terminal:</strong>
    <code>
1. GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are set in .env and loaded correctly
   → python manage.py shell -c "from django.conf import settings; print(settings.GOOGLE_CLIENT_ID[:8])"

2. Site domain matches SITE_ID=1
   → python manage.py shell -c "from django.contrib.sites.models import Site; print(Site.objects.get(id=1).domain)"
   Expected: 127.0.0.1:8000

3. No SocialApp row conflicts in DB
   → python manage.py shell -c "from allauth.socialaccount.models import SocialApp; print(list(SocialApp.objects.all()))"
   Expected: []

4. Authorised redirect URI in Google Cloud Console must be exactly:
   http://127.0.0.1:8000/accounts/google/login/callback/
    </code>
  </div>

  <div class="step">
    <a href="/login/">&larr; Back to login</a>
  </div>
</div>
</body>
</html>
</file>

<file path="templates/socialaccount/login.html">
{% load i18n socialaccount %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redirecting to Google…</title>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            font-family: Inter, Arial, sans-serif;
            background: #faf7f2;
            color: #1a1a1a;
        }
        .oauth-loader {
            text-align: center;
            padding: 2rem;
            border-radius: 18px;
            background: #fff;
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
            width: min(92vw, 420px);
        }
        .spinner {
            width: 38px;
            height: 38px;
            border: 4px solid #e9ecef;
            border-top-color: #1f8a70;
            border-radius: 50%;
            margin: 0 auto 1rem;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .hidden-submit {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
    </style>
</head>
<body>
    <div class="oauth-loader">
        <div class="spinner" aria-hidden="true"></div>
        <h2 style="margin: 0 0 0.5rem; font-size: 1.25rem;">Redirecting to {{ provider.name }}</h2>
        <p style="margin: 0 0 1rem; color: #6c757d;">Please wait while we open the account chooser.</p>

        <form id="social-login-redirect" method="post" action="{% provider_login_url provider.id process=process next=next %}">
            {% csrf_token %}
            <button type="submit" class="hidden-submit">{% trans "Continue" %}</button>
        </form>

        <noscript>
            <button type="submit" form="social-login-redirect" style="border: 0; border-radius: 12px; padding: 0.8rem 1rem; background: #1f8a70; color: #fff; font-weight: 600; cursor: pointer;">
                {% trans "Continue to provider" %}
            </button>
        </noscript>
    </div>

    <script>
        window.addEventListener('load', function () {
            document.getElementById('social-login-redirect').submit();
        });
    </script>
</body>
</html>
</file>

<file path="templates/transactions/swap_matches.html">
{% load static %}
{% include 'components/base/base-top.html' %}
{% include 'components/header/header.html' %}

<style>
  .swap-hero {
    padding: 40px 0 20px;
    background: radial-gradient(circle at 10% 0%, #f7f3eb 0%, #ffffff 40%, #eef6f3 100%);
  }
  .swap-title {
    font-family: 'Merriweather', serif;
    font-size: 26px;
    margin-bottom: 8px;
  }
  .swap-subtitle {
    color: #52616b;
    margin-bottom: 0;
  }
  .swap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 24px;
    margin-bottom: 40px;
  }
  .swap-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 14px 30px rgba(11, 31, 42, 0.12);
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .swap-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: #52616b;
  }
  .swap-userspan {
    font-weight: 600;
    color: #1f8a70;
  }
  .swap-body {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 10px;
    align-items: center;
  }
  .swap-book {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .swap-book img {
    width: 60px;
    height: 86px;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 6px 14px rgba(0,0,0,0.15);
  }
  .swap-book-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .swap-book-meta {
    font-size: 12px;
    color: #52616b;
  }
  .swap-icon {
    font-size: 22px;
    color: #f28f3b;
  }
  .swap-actions {
    margin-top: 8px;
    display: flex;
    justify-content: flex-end;
  }
  .swap-btn {
    border-radius: 999px;
    background: #1f8a70;
    color: #ffffff;
    border: none;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .swap-btn:hover {
    background: #176955;
    color: #ffffff;
  }
  .swap-empty {
    text-align: center;
    padding: 60px 0 80px;
  }
  .swap-empty h3 {
    font-family: 'Merriweather', serif;
    font-size: 22px;
    margin-bottom: 10px;
  }
  .swap-empty p {
    color: #52616b;
    margin-bottom: 0;
  }
  .swap-detail-box {
    border: 1px solid #e9e3d6;
    border-radius: 12px;
    padding: 10px;
    background: #fbf9f4;
    font-size: 12px;
    color: #52616b;
  }
  .swap-detail-box strong {
    color: #0b1f2a;
  }
</style>

<section class="swap-hero">
  <div class="container">
    <div class="row">
      <div class="col-lg-8">
        <h1 class="swap-title">Smart Book Swaps</h1>
        <p class="swap-subtitle">We automatically find perfect exchange partners based on what you have and what you want.</p>
      </div>
    </div>

    {% if messages %}
      <div class="row" style="margin-top: 10px;">
        <div class="col-lg-8">
          {% for message in messages %}
            <div class="alert alert-{{ message.tags }}" role="alert" style="margin-bottom: 6px;">
              {{ message }}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if matches %}
      <div class="swap-grid">
        {% for m in matches %}
          <div class="swap-card">
            <div class="swap-card-header">
              <span>Match with <span class="swap-userspan">{{ m.match_user.username }}</span></span>
              <span style="font-size: 12px; color: #f28f3b;">Perfect swap match 🔁</span>
            </div>
            <div class="swap-body">
              <div class="swap-book">
                <div>
                  {% if m.my_book.image %}
                      <img class="book-cover-img" src="{{ m.my_book.imageURL }}" alt="{{ m.my_book.Book_name }}" data-fallback="{% static 'images/default_cover.jpg' %}" onerror="this.onerror=null; this.src=this.dataset.fallback;">
                  {% else %}
                      <img class="book-cover-img" src="{% static 'images/default_cover.jpg' %}" alt="Book cover">
                  {% endif %}
                </div>
                <div>
                  <div class="swap-book-title">You Give: {{ m.my_book.Book_name }}</div>
                  <div class="swap-book-meta">{{ m.my_book.Author }} · {{ m.my_book.genre }}</div>
                </div>
              </div>

              <div class="swap-icon">🔁</div>

              <div class="swap-book">
                <div>
                  {% if m.their_book.image %}
                      <img class="book-cover-img" src="{{ m.their_book.imageURL }}" alt="{{ m.their_book.Book_name }}" data-fallback="{% static 'images/default_cover.jpg' %}" onerror="this.onerror=null; this.src=this.dataset.fallback;">
                  {% else %}
                      <img class="book-cover-img" src="{% static 'images/default_cover.jpg' %}" alt="Book cover">
                  {% endif %}
                </div>
                <div>
                  <div class="swap-book-title">You Get: {{ m.their_book.Book_name }}</div>
                  <div class="swap-book-meta">{{ m.their_book.Author }} · {{ m.their_book.genre }}</div>
                </div>
              </div>
            </div>

            <div class="swap-detail-box">
              <div><strong>Condition:</strong> {{ m.their_book.condition|default:"Not specified" }}</div>
              <div><strong>Location:</strong> {{ m.their_book.location|default:"Not specified" }}</div>
              <div><strong>Looking for:</strong> {{ m.their_book.swap_preference|default:"Open to offers"|truncatechars:60 }}</div>
            </div>

            <div class="swap-actions" style="gap: 8px;">
              <form method="post" action="{% url 'create_swap_request' %}">
                {% csrf_token %}
                <input type="hidden" name="my_book_id" value="{{ m.my_book.id }}">
                <input type="hidden" name="their_book_id" value="{{ m.their_book.id }}">
                <button type="submit" class="swap-btn">
                  Send Swap Request
                </button>
              </form>
              {% if m.their_book.contact_email %}
                <a
                  href="mailto:{{ m.their_book.contact_email }}?subject=Swap Request: {{ m.their_book.Book_name }} via BookLoop"
                  class="swap-btn"
                  style="background:#198754;"
                >
                  Contact via Email
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="swap-empty">
        <h3>No perfect swap matches yet</h3>
        <p>Keep adding books to your swap list and setting clear swap preferences. We'll notify you here as soon as we find a match.</p>
        <a href="{% url 'add_swap_book' %}" class="btn btn-primary btn-lg mt-3">
          Add Book to Swap
        </a>
      </div>
    {% endif %}
  </div>
</section>

