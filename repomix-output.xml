                <h5>{{ book.Book_name|truncatewords:5 }}</h5>
                <p>Author: {{ book.Author|truncatewords:4 }}</p>
                <p>Genre: {{ book.genre|truncatewords:3 }}</p>
                <div class="book-price">Rs. {{ book.price }}</div>
            </div>
            <div class="book-actions">
                <a href="{% url 'product' book.id %}"><i class="fas fa-arrow-right"></i> View</a>
