        <div class="book-card h-100">
            {% if book.image and "herald" not in book.image.url|lower and "college" not in book.image.url|lower %}
            <img class="book-cover-img" src="{{ book.image.url }}" alt="{{ book.Book_name }}" data-fallback="{% static 'images/default_cover.jpg' %}" onerror="this.onerror=null; this.src=this.dataset.fallback;">
