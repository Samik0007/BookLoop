  margin-bottom: 6px;
  color: var(--bw-ink);
}

.similar-meta {
  font-size: 12px;
  color: var(--bw-muted);
  margin-bottom: 10px;
}

.similar-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.similar-price {
  color: var(--bw-accent);
  font-weight: 800;
  font-size: 17px;
}

.similar-actions a {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--bw-accent), #14b8a6);
  padding: 8px 12px;
  border-radius: 12px;
  text-decoration: none;
}

@media (max-width: 991px) {
  .product-image img {
    max-height: 520px;
  }

  .product-highlight-bar,
  .product-actions {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 767px) {
  .product-shell {
    padding: 22px;
    border-radius: 24px;
  }

  .product-title {
    font-size: 28px;
  }
}

.star-rating {
  display: inline-flex;
  flex-direction: row-reverse;
  gap: 6px;
}

.star-rating input {
  display: none;
}

.star-rating label {
  cursor: pointer;
  font-size: 26px;
  line-height: 1;
  color: var(--bs-gray-400);
}

.star-rating label:hover,
.star-rating label:hover ~ label {
  color: var(--bs-warning);
}

.star-rating input:checked ~ label {
  color: var(--bs-warning);
}
</style>

{% if data %}
<section class="product-hero">
  <div class="container">
    <div class="product-shell">
      <div class="product-card">
        <div class="row g-4 align-items-start">
          <div class="col-lg-5">
            <div class="product-image-wrap">
              <div class="product-floating-badge">
                <i class="fas fa-book-open"></i>
                Handpicked title
              </div>
              <div class="product-image">
                {% if data.imageURL and "herald" not in data.imageURL|lower and "college" not in data.imageURL|lower %}
                <img src="{{ data.imageURL }}" alt="{{ data.Book_name }}" class="img-fluid shadow-sm bw-main-cover {% if data.listing_type == 'swap' %}bw-main-cover--swap{% endif %}" data-fallback="{% static 'images/default_cover.jpg' %}" onerror="this.onerror=null; this.src=this.dataset.fallback;">
                {% else %}
                <img src="{% static 'images/default_cover.jpg' %}" alt="{{ data.Book_name }}" class="img-fluid shadow-sm bw-main-cover {% if data.listing_type == 'swap' %}bw-main-cover--swap{% endif %}">
                {% endif %}
              </div>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="product-content">
              <div class="product-eyebrow">
                <i class="fas fa-magic"></i>
                Modern book details
              </div>

              <div class="product-title">{{ data.Book_name }}</div>

              <div class="product-meta-row">
                <span class="product-meta-chip"><i class="fas fa-user-edit"></i> {{ data.Author }}</span>
                <span class="product-meta-chip"><i class="fas fa-layer-group"></i> {{ data.genre }}</span>
              </div>

              <p class="product-description">{{ data.description }}</p>

              {% if data.listing_type == 'sell' %}
                <div style="margin: 10px 0 14px;">
                  {% if data.rating_count %}
                    <p class="text-muted" style="margin: 0 0 8px;">
                      <i class="fas fa-star text-warning"></i>
                      {{ data.average_rating|floatformat:1 }} / 5 (Based on {{ data.rating_count }} reviews)
                    </p>
                  {% else %}
                    <p class="text-muted" style="margin: 0 0 8px;">
                      <i class="fas fa-star text-warning"></i>
                      No ratings yet
                    </p>
                  {% endif %}

                  {% if user.is_authenticated %}
                    {% for message in messages %}
                      {% if message.level == 25 %}
                        <div class="rating-feedback" style="margin-bottom:10px;padding:8px 14px;border-radius:10px;font-size:0.85rem;background:#dcfce7;color:#166534;border:1px solid #86efac;">
                          <i class="fas fa-check-circle"></i> {{ message }}
                        </div>
                      {% elif message.level == 40 %}
                        <div class="rating-feedback" style="margin-bottom:10px;padding:8px 14px;border-radius:10px;font-size:0.85rem;background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;">
                          <i class="fas fa-times-circle"></i> {{ message }}
                        </div>
                      {% endif %}
                    {% endfor %}
                    <form method="POST" action="{% url 'rate_book' data.id %}">
                      {% csrf_token %}
                      <div class="star-rating" aria-label="Rate this book">
                        <input type="radio" id="rating-5" name="score" value="5" {% if user_rating == 5 %}checked{% endif %}>
                        <label for="rating-5" title="5 stars">★</label>
                        <input type="radio" id="rating-4" name="score" value="4" {% if user_rating == 4 %}checked{% endif %}>
                        <label for="rating-4" title="4 stars">★</label>
                        <input type="radio" id="rating-3" name="score" value="3" {% if user_rating == 3 %}checked{% endif %}>
                        <label for="rating-3" title="3 stars">★</label>
                        <input type="radio" id="rating-2" name="score" value="2" {% if user_rating == 2 %}checked{% endif %}>
                        <label for="rating-2" title="2 stars">★</label>
                        <input type="radio" id="rating-1" name="score" value="1" {% if user_rating == 1 %}checked{% endif %}>
                        <label for="rating-1" title="1 star">★</label>
                      </div>
                      <div>
                        <button type="submit" class="btn btn-outline-primary btn-sm" style="margin-top: 10px; border-radius: 14px;">
                          Submit Rating
                        </button>
                      </div>
                    </form>
                  {% else %}
                    <p class="text-muted" style="margin: 0;">Login to rate this book.</p>
                  {% endif %}
                </div>

                <div class="product-highlight-bar">
                  <div class="product-highlight">
                    <small>Delivery</small>
                    <strong>2-4 business days</strong>
                  </div>
                  <div class="product-highlight">
                    <small>Checkout</small>
                    <strong>Fast & secure</strong>
                  </div>
                </div>

                <div class="product-price-panel">
                  <div>
                    <div class="product-price-label">Price</div>
                    <div class="product-price">Rs. {{ data.discounted_price }}</div>
                    <div style="font-size:.82rem;color:var(--bw-muted);text-decoration:line-through;margin-top:2px;">
                      Rs. {{ data.price }}
                    </div>
                  </div>
                  {% if data.quantity == 0 %}
                    <span class="product-stock stock-empty">
                      <i class="fas fa-times-circle"></i>
                      Out of stock
                    </span>
                  {% else %}
                    <span class="product-stock stock-available">
                      <i class="fas fa-check-circle"></i>
                      {{ data.quantity }} in stock
                    </span>
                  {% endif %}
                </div>

                {% if other_sellers %}
                <div style="background:#f8fafc;border:1px solid rgba(148,163,184,.18);border-radius:14px;padding:14px 16px;margin-bottom:14px;">
                  <div style="font-size:.75rem;font-weight:700;color:var(--bw-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;">
                    <i class="fas fa-store"></i>&nbsp; Other sellers offering this book
                  </div>
                  {% for sp in other_sellers %}
                  <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(148,163,184,.10);">
                    <div>
                      <div style="font-size:.88rem;font-weight:600;color:var(--bw-ink);">
                        {% if sp.seller %}{{ sp.seller.username }}{% else %}BookLoop Store{% endif %}
                      </div>
                      <div style="font-size:.76rem;color:var(--bw-muted);">
                        {{ sp.quantity }} in stock{% if sp.condition %}&nbsp;·&nbsp;{{ sp.condition }}{% endif %}
                      </div>
                    </div>
                    <div style="font-size:1rem;font-weight:800;color:var(--bw-accent);">Rs. {{ sp.discounted_price }}</div>
                  </div>
                  {% endfor %}
                </div>
                {% endif %}

                <div id="cart-msg"></div>

                <div class="product-actions">
                  <button data-product="{{ data.id }}" data-action="add" class="btn btn-cart update-cart">
                    <i class="fas fa-cart-plus"></i>
                    Add to Cart
                  </button>
                  <button class="btn btn-buy btn-buy-now" type="button" data-product="{{ data.id }}">
                    <i class="fas fa-bolt"></i>
                    Buy Now
                  </button>
                  <button class="btn btn-wish addToWishlist" data-product="{{ data.id }}">
                    <i class="fas fa-heart"></i>
                    Save to Wishlist
                  </button>
                </div>
              {% elif data.listing_type == 'swap' %}
                <div class="product-price-panel" style="gap: 12px;">
                  <div style="width: 100%;">
                    <div class="product-price-label">Swap Details</div>

                    <div style="display: grid; gap: 10px; margin-top: 10px;">
                      <div class="product-highlight" style="margin: 0;">
                        <small>Owner</small>
                        <strong>
                          {% if data.seller %}
                            {% if data.seller.get_full_name %}
                              {{ data.seller.get_full_name }}
                            {% else %}
                              {{ data.seller.username }}
                            {% endif %}
                          {% else %}
                            BookLoop User
                          {% endif %}
                        </strong>
                      </div>

                      <div class="product-highlight" style="margin: 0;">
                        <small>Location</small>
                        <strong>{{ data.location|default:"Not specified" }}</strong>
                      </div>

                      <div class="product-highlight" style="margin: 0;">
                        <small>Condition</small>
                        <strong>{{ data.condition|default:"Not specified" }}</strong>
                      </div>

                      <div class="product-highlight" style="margin: 0;">
                        <small>Looking For</small>
                        <strong>{{ data.swap_preference|default:"Open to offers" }}</strong>
                      </div>
                    </div>

                    {% with email=data.contact_email|default:data.seller.email %}
                      {% if email %}
                        <a href="mailto:{{ email }}?subject=Swap Request: {{ data.Book_name }} via BookLoop" class="btn btn-primary btn-lg w-100" style="margin-top: 16px; border-radius: 18px;">
                          <i class="fas fa-envelope"></i>
                          Contact Owner to Swap
                        </a>
                      {% else %}
                        <div class="alert alert-warning" style="margin-top: 16px; border-radius: 18px;">
                          Contact email is not available for this swap listing.
                        </div>
                      {% endif %}
                    {% endwith %}
                  </div>
                </div>
              {% elif data.listing_type == 'donate' %}
                <div class="product-price-panel" style="gap: 12px;">
                  <div style="width: 100%;">
                    <div class="product-price-label">Donation Details</div>

                    <div style="display: grid; gap: 10px; margin-top: 10px;">
                      <div class="product-highlight" style="margin: 0;">
                        <small>Donor</small>
                        <strong>
                          {% if data.seller %}
                            {% if data.seller.get_full_name %}
                              {{ data.seller.get_full_name }}
                            {% else %}
                              {{ data.seller.username }}
                            {% endif %}
                          {% else %}
                            BookLoop User
                          {% endif %}
                        </strong>
                      </div>

                      <div class="product-highlight" style="margin: 0;">
                        <small>Location</small>
                        <strong>{{ data.location|default:"Not specified" }}</strong>
                      </div>

                      <div class="product-highlight" style="margin: 0;">
                        <small>Condition</small>
                        <strong>{{ data.condition|default:"Not specified" }}</strong>
                      </div>
                    </div>

                    {% with email=data.contact_email|default:data.seller.email %}
                      {% if email %}
                        <a href="mailto:{{ email }}?subject=Donation Interest: {{ data.Book_name }} via BookLoop" class="btn btn-success btn-lg w-100" style="margin-top: 16px; border-radius: 18px;">
                          <i class="fas fa-envelope"></i>
                          Contact Donor
                        </a>
                      {% else %}
                        <div class="alert alert-warning" style="margin-top: 16px; border-radius: 18px;">
                          Contact email is not available for this donation listing.
                        </div>
                      {% endif %}
                    {% endwith %}

                    <div class="alert alert-light border" style="margin-top: 14px; border-radius: 18px;">
                      This is a free donation listing. Distribution is coordinated after admin approval.
                    </div>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>

          <div class="col-lg-3">
            {% if data.listing_type == 'sell' %}
              <div class="product-side">
                <h5>Why you'll love it</h5>

                <div class="side-feature">
                  <i class="fas fa-undo-alt"></i>
                  <div>
                    <strong>Easy returns</strong>
                    <span>Return or replace within 7 days for a smoother shopping experience.</span>
                  </div>
                </div>

                <div class="side-feature">
                  <i class="fas fa-shield-alt"></i>
                  <div>
                    <strong>Protected purchase</strong>
                    <span>Secure checkout flow built for safe payments and trusted ordering.</span>
                  </div>
                </div>

                <div class="side-feature">
                  <i class="fas fa-magic"></i>
                  <div>
                    <strong>Smart recommendations</strong>
                    <span>Discover similar titles based on genre, author, and reading behavior.</span>
                  </div>
                </div>

                <div class="side-feature">
                  <i class="fas fa-gift"></i>
                  <div>
                    <strong>Perfect for gifting</strong>
                    <span>A stylish choice for readers, collectors, and thoughtful presents.</span>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <section class="similar-section">
        <div class="similar-header">
          <h3>You May Also Like</h3>
          <p>Similar books selected from your current interest in author and genre.</p>
        </div>

        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4 justify-content-start similar-grid">
          {% for book in similar_books %}
          <div class="col">
            <div class="similar-card h-100">
              {% if book.image and "herald" not in book.image.url|lower and "college" not in book.image.url|lower %}
                <img class="card-img-top book-cover-img" src="{{ book.image.url }}" alt="{{ book.Book_name }}" data-fallback="{% static 'images/default_cover.jpg' %}" onerror="this.onerror=null; this.src=this.dataset.fallback;" style="width: 100%; height: 280px; object-fit: cover; object-position: center; border-radius: inherit;">
              {% else %}
                <img class="card-img-top book-cover-img" src="{% static 'images/default_cover.jpg' %}" alt="{{ book.Book_name }}" style="width: 100%; height: 280px; object-fit: cover; object-position: center; border-radius: inherit;">
              {% endif %}
              <div class="similar-body">
                <h6>{{ book.Book_name|truncatewords:4 }}</h6>
                <div class="similar-meta">{{ book.Author|truncatewords:2 }}</div>
                <div class="similar-price-row">
                  <div class="similar-price">Rs. {{ book.price }}</div>
                  <div class="similar-actions">
                    <a href="{% url 'product' book.id %}">
                      View
                      <i class="fas fa-arrow-right"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          {% empty %}
          <p style="color: var(--bw-muted); margin-top: 14px;">No similar books found.</p>
          {% endfor %}
        </div>
      </section>
    </div>
  </div>
</section>
{% else %}
<section class="product-hero">
  <div class="container">
    <div class="product-shell">
      <h2 class="product-title">Book not available</h2>
      <p class="product-description">This book may have been removed or is unavailable right now.</p>
      <a href="{% url 'store' %}" class="btn btn-cart">Back to Store</a>
    </div>
  </div>
</section>
{% endif %}

<script>
  var updateBtns = document.getElementsByClassName('update-cart')

  for (var i = 0; i < updateBtns.length; i++) {
    updateBtns[i].addEventListener('click', function () {
      var productId = this.dataset.product
      var action = this.dataset.action
      console.log('productId:', productId, 'Action:', action)

      if (user == 'AnonymousUser') {
        alert('Please login first to add items to cart!')
        window.location.href = '/login/'
      } else {
        addToCart(productId, action)
      }
    })

  var buyNowBtns = document.getElementsByClassName('btn-buy-now')
  for (var j = 0; j < buyNowBtns.length; j++) {
    buyNowBtns[j].addEventListener('click', function(e) {
      var productId = this.dataset.product
      buyNow(e, productId)
    })
  }
  }

  function addToCart(productId, action) {
    var url = '/update_item/'
    var msgBox = document.getElementById('cart-msg')

    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRFToken': csrftoken,
      },
      body: JSON.stringify({ 'productId': productId, 'action': action })
    })
      .then((response) => response.json())
      .then((data) => {
        if (data.error === 'out_of_stock') {
          if (msgBox) {
            msgBox.style.display = 'block'
            msgBox.style.background = '#fee2e2'
            msgBox.style.color = '#991b1b'
            msgBox.style.border = '1px solid #fca5a5'
            msgBox.innerHTML = '<i class="fas fa-times-circle"></i> This book is out of stock.'
          }
          return
        }
        if (msgBox) {
          msgBox.style.display = 'block'
          msgBox.style.background = '#dcfce7'
          msgBox.style.color = '#166534'
          msgBox.style.border = '1px solid #86efac'
          msgBox.innerHTML = '<i class="fas fa-check-circle"></i> Item added to cart successfully!'
          setTimeout(function () { location.reload() }, 900)
        } else {
          location.reload()
        }
      })
  }

  function buyNow(event, productId) {
    event.preventDefault()

    if (user == 'AnonymousUser') {
      alert('Please login first to buy items!')
      window.location.href = '/login/'
      return
    }

    var msgBox = document.getElementById('cart-msg')
    if (msgBox) {
      msgBox.style.display = 'block'
      msgBox.style.background = '#e0f2fe'
      msgBox.style.color = '#0c4a6e'
      msgBox.style.border = '1px solid #7dd3fc'
      msgBox.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Preparing express checkout...'
    }

    var url = '/update_item/'
    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRFToken': csrftoken,
      },
      body: JSON.stringify({ 'productId': productId, 'action': 'add' })
    })
      .then((response) => response.json())
      .then((data) => {
        if (data.error === 'out_of_stock') {
          var msgBox = document.getElementById('cart-msg')
          if (msgBox) {
            msgBox.style.display = 'block'
            msgBox.style.background = '#fee2e2'
            msgBox.style.color = '#991b1b'
            msgBox.style.border = '1px solid #fca5a5'
            msgBox.innerHTML = '<i class="fas fa-times-circle"></i> This book is out of stock.'
          }
          return
        }
        window.location.href = '/checkout/?buy_now=' + productId
      })
  }

  var wishBtns = document.getElementsByClassName('addToWishlist')
  for (var j = 0; j < wishBtns.length; j++) {
    wishBtns[j].addEventListener('click', function () {
      var productId = this.dataset.product
      if (user == 'AnonymousUser') {
        alert('Please login first to add items to wishlist!')
        window.location.href = '/login/'
        return
      }

      fetch('/add-to-wishlist', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-CSRFToken': csrftoken
        },
        body: 'product_id=' + productId
      })
        .then((response) => response.json())
        .then((data) => {
          var msgBox = document.getElementById('cart-msg')
          if (msgBox) {
            msgBox.style.display = 'block'
            msgBox.style.background = '#fff7ed'
            msgBox.style.color = '#9a3412'
            msgBox.style.border = '1px solid #fdba74'
            msgBox.innerHTML = '<i class="fas fa-heart"></i> Added to wishlist'
          }
        })
    })
  }
</script>

