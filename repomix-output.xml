<!-- ── Order Success Modal ──────────────────────────────────────────────── -->
<div id="bw-success-overlay" style="
    display:none; position:fixed; inset:0; z-index:99999;
    background:rgba(11,31,42,0.7); backdrop-filter:blur(4px);
    align-items:center; justify-content:center;">
