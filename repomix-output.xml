<body>

<!-- ─── LEFT — BOOK IMAGE SHOWCASE ─── -->
<div class="left-panel">
    <div class="bg-image"></div>
    <div class="overlay"></div>

    <div class="book-quote">
        <p>"The more that you read, the more things you will know. The more that you learn, the more places you'll go."</p>
        <cite>— Dr. Seuss</cite>
    </div>

    <div class="left-content">
        <div class="logo-area">
            <div class="logo-icon"><i class="fa-solid fa-book-open"></i></div>
            <h3>Book <span>Loop</span></h3>
        </div>
        <h1>Start Your<br><em>Reading Journey</em></h1>
        <p class="tagline">Create your free account and explore a world of curated books handpicked just for you.</p>

        <ul class="journey-steps">
            <li><span class="step-num">1</span> Create your free account</li>
            <li><span class="step-num">2</span> Verify with a one-time code</li>
            <li><span class="step-num">3</span> Get personalised book picks</li>
            <li><span class="step-num">4</span> Start reading &amp; shopping!</li>
        </ul>
    </div>
</div>

<!-- ─── RIGHT — REGISTER FORM ─── -->
<div class="right-panel">
    <div class="form-card">
        <div class="mobile-logo"><h2>Book <span>Loop</span></h2></div>

        <a href="{% url 'home' %}" class="home-link">
            <i class="fa-solid fa-arrow-left"></i> Back to Home
        </a>

        <h2>Create your account</h2>
        <p class="subtitle">Start your reading journey today — it's free!</p>

        <!-- Messages -->
        {% if messages %}
            {% for message in messages %}
                <div class="alert-box {% if 'success' in message.tags %}success{% elif 'error' in message.tags %}danger{% elif 'warning' in message.tags %}warning{% else %}warning{% endif %}">
                    <i class="fa-solid {% if 'success' in message.tags %}fa-circle-check{% elif 'warning' in message.tags %}fa-triangle-exclamation{% else %}fa-circle-info{% endif %}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endif %}

        {% if form.errors %}
            <div class="alert-box danger">
                <i class="fa-solid fa-circle-exclamation"></i>
                Please fix the errors below to continue.
            </div>
        {% endif %}

        <!-- Google -->
        <form action="{% provider_login_url 'google' process='signup' %}" method="post" class="d-grid mb-3">
            {% csrf_token %}
            <button type="submit" class="btn-google border-0 shadow-sm">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" style="width: 20px; height: 20px; margin-right: 10px;">
                Continue with Google
            </button>
        </form>

        <div class="divider">or register with email</div>

        <!-- Form -->
        <form method="POST" action="{% url 'reg' %}">
            {% csrf_token %}

            <div class="row-2col">
                <div class="field">
                    <label for="id_first_name">First Name</label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-user"></i>
                        <input type="text" id="id_first_name" name="first_name" placeholder="Samik" required value="{{ form.first_name.value|default:'' }}">
                    </div>
                    {% if form.first_name.errors %}<span class="error-text">{{ form.first_name.errors.0 }}</span>{% endif %}
                </div>
                <div class="field">
                    <label for="id_last_name">Last Name</label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-user"></i>
                        <input type="text" id="id_last_name" name="last_name" placeholder="Bhandari" required value="{{ form.last_name.value|default:'' }}">
                    </div>
                    {% if form.last_name.errors %}<span class="error-text">{{ form.last_name.errors.0 }}</span>{% endif %}
                </div>
            </div>

            <div class="field">
                <label for="id_username">Username</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-at"></i>
                    <input type="text" id="id_username" name="username" placeholder="Choose a username" required value="{{ form.username.value|default:'' }}">
                </div>
                {% if form.username.errors %}<span class="error-text">{{ form.username.errors.0 }}</span>{% endif %}
            </div>

            <div class="field">
                <label for="id_email">Email Address</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-envelope"></i>
                    <input type="email" id="id_email" name="email" placeholder="your@email.com" required value="{{ form.email.value|default:'' }}">
                </div>
                {% if form.email.errors %}<span class="error-text">{{ form.email.errors.0 }}</span>{% endif %}
            </div>

            <div class="field">
                <label for="id_password1">Password</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="id_password1" name="password1" placeholder="Create a strong password" required autocomplete="new-password">
                </div>
                {% if form.password1.errors %}<span class="error-text">{{ form.password1.errors.0 }}</span>{% endif %}
                <div class="strength-bar"><div class="fill" id="strengthLevel"></div></div>
            </div>

            <div class="field">
                <label for="id_password2">Confirm Password</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-shield-halved"></i>
                    <input type="password" id="id_password2" name="password2" placeholder="Re-enter your password" required autocomplete="new-password">
                </div>
                {% if form.password2.errors %}<span class="error-text">{{ form.password2.errors.0 }}</span>{% endif %}
                <span class="help-text">Min 8 characters with letters, numbers &amp; symbols.</span>
            </div>

            <div class="radio-group">
                <label class="group-label">Register as</label>
                <div class="radio-row">
                    <label><input type="radio" name="register_as" value="student" checked> Student</label>
                    <label><input type="radio" name="register_as" value="bookshop"> Bookshop</label>
                </div>
            </div>

            <div class="terms">
                <input type="checkbox" id="terms" name="terms" required>
                <label for="terms">I agree to the <a href="#">Terms &amp; Conditions</a> and <a href="#">Privacy Policy</a></label>
            </div>

            {% if form.non_field_errors %}
                <div class="alert-box danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {% for error in form.non_field_errors %}{{ error }}{% endfor %}
                </div>
            {% endif %}

            <button type="submit" class="btn-submit">
                <i class="fa-solid fa-user-plus"></i>&nbsp; Create Account
            </button>
        </form>

        <div class="bottom-link">
            Already have an account? <a href="{% url 'login' %}">Sign in</a>
        </div>
        <div class="footer-text">
            Developed by <strong>Samik Bhandari</strong> · Book Loop &copy; 2026
        </div>
    </div>
</div>

<script>
    document.getElementById('id_password1').addEventListener('input', function () {
        var pw = this.value, bar = document.getElementById('strengthLevel'), s = 0;
        if (pw.length >= 8) s += 25;
        if (/[a-z]/.test(pw) && /[A-Z]/.test(pw)) s += 25;
        if (/\d/.test(pw)) s += 25;
        if (/[^a-zA-Z0-9]/.test(pw)) s += 25;
        bar.style.width = s + '%';
        bar.style.background = s <= 25 ? '#ef4444' : s <= 50 ? '#f59e0b' : s <= 75 ? '#3b82f6' : '#22c55e';
    });

    // Show loading state on form submit so user knows it's working
    var regForm = document.querySelector('form');
    var submitBtn = document.querySelector('.btn-submit');
    if (regForm && submitBtn) {
        regForm.addEventListener('submit', function () {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>&nbsp; Creating account...';
            submitBtn.style.opacity = '0.8';
            submitBtn.style.cursor = 'not-allowed';
        });
    }
</script>
</body>
</html>
</file>

