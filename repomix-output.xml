          padding:10px 24px; border-radius:10px; border:1px solid #dde3e9;
          background:#fff; font-weight:600; cursor:pointer; font-size:0.9rem;
          color:#52616b; transition:background 0.18s;"
        onmouseover="this.style.background='#f5f5f5'" onmouseout="this.style.background='#fff'">
        Cancel
      </button>
      <button id="remove-confirm" style="
          padding:10px 24px; border-radius:10px; border:none;
          background:#dc3545; color:#fff; font-weight:700; cursor:pointer; font-size:0.9rem;
          transition:background 0.18s;"
        onmouseover="this.style.background='#bb2d3b'" onmouseout="this.style.background='#dc3545'">
        Yes, Remove
      </button>
    </div>
  </div>
</div>

<script>
  // ── Remove-from-cart dialog ────────────────────────────────────────────────
  var pendingRemoveForm = null;

  document.querySelectorAll('.remove-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      pendingRemoveForm = this.closest('.remove-form');
      document.getElementById('remove-book-name').textContent = '"' + this.dataset.name + '"';
      var overlay = document.getElementById('remove-overlay');
      var card    = document.getElementById('remove-card');
      overlay.style.display = 'flex';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          card.style.transform = 'scale(1)';
          card.style.opacity   = '1';
        });
      });
    });
  });

  function closeRemoveDialog() {
    var overlay = document.getElementById('remove-overlay');
    var card    = document.getElementById('remove-card');
    card.style.transform = 'scale(0.9)';
    card.style.opacity   = '0';
    setTimeout(function() { overlay.style.display = 'none'; }, 220);
    pendingRemoveForm = null;
  }

  document.getElementById('remove-cancel').addEventListener('click', closeRemoveDialog);
  document.getElementById('remove-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeRemoveDialog();
  });
  document.getElementById('remove-confirm').addEventListener('click', function() {
    if (pendingRemoveForm) pendingRemoveForm.submit();
  });

  var updateBtns = document.getElementsByClassName('update-cart')

  for (var i = 0; i < updateBtns.length; i++) {
    updateBtns[i].addEventListener('click', function () {
      var productId = this.dataset.product
      var action = this.dataset.action

      if (user == 'AnonymousUser') {
        alert('Please login first to update your cart!')
        window.location.href = '/login/'
      } else {
        updateUserOrder(productId, action)
      }
    })
  }

  function updateUserOrder(productId, action) {
    var url = '/update_item/'

    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRFToken': csrftoken,
      },
      body: JSON.stringify({ 'productId': productId, 'action': action })
    })
      .then((response) => response.json())
      .then((data) => {
        location.reload()
      })
  }

  // Wishlist buttons in cart
  document.querySelectorAll('.wish-btn').forEach(function(btn) {
    if (btn.dataset.saved === 'true') {
      btn.classList.add('saved');
    }

    btn.addEventListener('click', function() {
      var productId = this.dataset.productId;
      var self = this;

      if (typeof user !== 'undefined' && user === 'AnonymousUser') {
        window.location.href = '/login/';
        return;
      }

      fetch('/add-to-wishlist', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-CSRFToken': csrftoken,
        },
        body: 'product_id=' + productId,
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        self.classList.add('saved');
        self.dataset.saved = 'true';
        self.querySelector('span').textContent = 'Saved';
        self.querySelector('i').style.color = '#e11d48';
      })
      .catch(function() {
        window.location.href = '/product/' + productId + '/';
      });
    });
  });
</script>

