<div class="donate-wrap">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-xl-7">

        <div class="donate-card">

          <!-- ── Header ── -->
          <div class="donate-header">
            <h2><i class="fas fa-hand-holding-heart me-2" style="opacity:.85;"></i>Donate a Book</h2>
            <p>Give your book a second life by helping another student.</p>
          </div>

          <!-- ── Body ── -->
          <div class="donate-body">

            <!-- Donor info -->
            <div class="donor-badge">
              <div class="badge-icon"><i class="fas fa-user"></i></div>
              <div class="badge-text">
                <strong>
                  Donating as:
                  {% if request.user.get_full_name %}{{ request.user.get_full_name }}{% else %}{{ request.user.username }}{% endif %}
                </strong>
                <span>Your donation will be visible after admin approval.</span>
              </div>
            </div>

            <!-- Non-field errors -->
            {% if form.non_field_errors %}
              <div class="alert alert-danger rounded-3 mb-4" role="alert">
                {% for error in form.non_field_errors %}<div>{{ error }}</div>{% endfor %}
              </div>
            {% endif %}

            <form method="POST" enctype="multipart/form-data">
              {% csrf_token %}

              <!-- Row 1: Title + Author -->
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label for="{{ form.Book_name.id_for_label }}" class="form-label">Book Title</label>
                  {{ form.Book_name }}
                  {% if form.Book_name.errors %}<div class="field-error">{% for e in form.Book_name.errors %}{{ e }}{% endfor %}</div>{% endif %}
                </div>
                <div class="col-md-6">
                  <label for="{{ form.Author.id_for_label }}" class="form-label">Author</label>
                  {{ form.Author }}
                  {% if form.Author.errors %}<div class="field-error">{% for e in form.Author.errors %}{{ e }}{% endfor %}</div>{% endif %}
                </div>
              </div>

              <!-- Row 2: Condition + Pickup Location -->
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label for="{{ form.condition.id_for_label }}" class="form-label">Book Condition</label>
                  {{ form.condition }}
                  {% if form.condition.errors %}<div class="field-error">{% for e in form.condition.errors %}{{ e }}{% endfor %}</div>{% endif %}
                </div>
                <div class="col-md-6">
                  <label for="{{ form.location.id_for_label }}" class="form-label">Pickup Location</label>
                  {{ form.location }}
                  {% if form.location.errors %}<div class="field-error">{% for e in form.location.errors %}{{ e }}{% endfor %}</div>{% endif %}
                </div>
              </div>

              <!-- Row 3: Contact Email (full width) -->
              <div class="mb-3">
                <label for="{{ form.contact_email.id_for_label }}" class="form-label">Contact Email</label>
                {{ form.contact_email }}
                {% if form.contact_email.errors %}<div class="field-error">{% for e in form.contact_email.errors %}{{ e }}{% endfor %}</div>{% endif %}
              </div>

              <!-- Row 4: Book Image (full width) -->
              <div class="mb-3">
                <label for="{{ form.image.id_for_label }}" class="form-label">Book Image <span class="text-muted fw-normal">(optional)</span></label>
                {{ form.image }}
                {% if form.image.help_text %}<small class="text-muted d-block mt-1">{{ form.image.help_text }}</small>{% endif %}
                {% if form.image.errors %}<div class="field-error">{% for e in form.image.errors %}{{ e }}{% endfor %}</div>{% endif %}
              </div>

