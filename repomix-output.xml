  color: var(--bw-ink);
}

.store-pill span {
  font-size: 12px;
  color: var(--bw-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.store-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
}

.store-card {
  position: relative;
  border-radius: 24px;
  overflow: hidden;
  background: var(--bw-surface);
  border: 1px solid rgba(255, 255, 255, 0.75);
  box-shadow: var(--bw-shadow);
  display: flex;
  flex-direction: column;
  min-height: 100%;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.store-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--bw-shadow-hover);
}

.store-card-media {
  position: relative;
  padding: 18px 18px 0;
}

.store-card-media::before {
  content: "";
  position: absolute;
  inset: 18px 18px auto;
  height: 72%;
  border-radius: 22px;
  background: linear-gradient(135deg, rgba(15, 118, 110, 0.16), rgba(249, 115, 22, 0.14));
}

.store-card img {
  position: relative;
  width: 100%;
  aspect-ratio: 2 / 3;         /* fixed portrait ratio — no zooming or cropping */
  height: auto;
  object-fit: contain;
  background: #f0eee9;         /* warm neutral shows full cover without cutting any text */
  border-radius: 18px;
  box-shadow: 0 16px 28px rgba(15, 23, 42, 0.14);
}

.store-badge {
  position: absolute;
  left: 32px;
  top: 32px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255, 255, 255, 0.92);
  color: var(--bw-accent);
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 11px;
  font-weight: 700;
  box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
}

.store-body {
  padding: 18px 20px 20px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.store-body h5 {
  font-size: 19px;
  line-height: 1.45;
  margin-bottom: 10px;
  color: var(--bw-ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.store-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.store-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #475569;
  background: #f8fafc;
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 999px;
  padding: 7px 10px;
}

.store-price-row {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
}

.store-price {
  color: var(--bw-accent);
  font-weight: 800;
  font-size: 22px;
  line-height: 1;
}

.store-price small {
  display: block;
  color: var(--bw-muted);
  font-size: 12px;
  font-weight: 500;
  margin-bottom: 4px;
}

.store-rating {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #f59e0b;
  background: #fffaf0;
  border-radius: 999px;
  padding: 8px 10px;
}

.store-actions {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 10px;
  margin-top: auto;
}

.store-actions .btn-details,
.store-actions .icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 46px;
  border-radius: 14px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s ease;
}

.store-actions .btn-details {
  background: linear-gradient(135deg, var(--bw-accent), #14b8a6);
  color: #fff;
  border: none;
  box-shadow: 0 12px 24px rgba(15, 118, 110, 0.22);
}

.store-actions .btn-details:hover {
  color: #fff;
  transform: translateY(-2px);
}

.store-actions .icon-btn {
  width: 48px;
  border: 1px solid rgba(148, 163, 184, 0.24);
  background: #fff;
  color: var(--bw-ink);
  box-shadow: 0 10px 18px rgba(15, 23, 42, 0.06);
}

.store-actions .icon-btn:hover {
  transform: translateY(-2px);
}

.store-actions .cart-btn:hover {
  color: var(--bw-accent);
  border-color: rgba(15, 118, 110, 0.35);
  background: var(--bw-accent-soft);
}

.store-actions .wish-btn:hover {
  color: #e11d48;
  border-color: rgba(225, 29, 72, 0.25);
  background: rgba(225, 29, 72, 0.08);
}

.empty-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 48px 24px;
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.85);
  border: 1px dashed rgba(148, 163, 184, 0.35);
}

.empty-state i {
  font-size: 42px;
  color: var(--bw-accent);
  margin-bottom: 14px;
}

.empty-state h4 {
  color: var(--bw-ink);
  margin-bottom: 8px;
}

.empty-state p {
  color: var(--bw-muted);
  margin: 0;
}

@media (max-width: 767px) {
  .store-shell {
    padding: 22px;
    border-radius: 24px;
  }

  .store-title {
    font-size: 28px;
  }

  .store-actions {
    grid-template-columns: 1fr 1fr 1fr;
  }
}
</style>

<section class="store-hero">
  <div class="container">
    <div class="store-shell">
      <div class="store-topbar">
        <div>
          <div class="store-eyebrow"><i class="fas fa-sparkles"></i> Curated collection</div>
          <div class="store-title">Discover Your Next Favorite Book</div>
          <p class="store-subtitle">A cleaner, more premium bookstore experience with faster browsing, modern cards, and polished actions for cart and wishlist.</p>
        </div>
        <div class="store-summary">
          <div class="store-pill">
            <strong>{{ products|length }}</strong>
            <span>Books Available</span>
          </div>
          <div class="store-pill">
            <strong>Fast</strong>
            <span>Cart & Wishlist</span>
          </div>
        </div>
      </div>

      <div class="store-grid">
        {% for product in products %}
        <div class="store-card">
          <div class="store-card-media">
            <div class="store-badge"><i class="fas fa-book-open"></i> Featured</div>
            <a href="{% url 'product' product.id %}">
              {% if product.image %}
              <img class="book-cover-img" src="{{ product.image.url }}" alt="{{ product.Book_name }}" data-fallback="{% static 'images/default_cover.jpg' %}" onerror="this.onerror=null; this.src=this.dataset.fallback;">
              {% else %}
              <img class="book-cover-img" src="{% static 'images/default_cover.jpg' %}" alt="{{ product.Book_name }}">
              {% endif %}
            </a>
          </div>
          <div class="store-body">
            <h5>{{ product.Book_name }}</h5>
            <div class="store-meta-row">
              <span class="store-chip"><i class="fas fa-layer-group"></i> {{ product.genre }}</span>
              <span class="store-chip"><i class="fas fa-user-edit"></i> {{ product.Author }}</span>
            </div>
            <div class="store-price-row">
              <div class="store-price">
                <small>Starting from</small>
                Rs {{ product.price|floatformat:2 }}
              </div>
              <div class="store-rating">
                <i class="fas fa-star"></i>
                <span>
                  {% if product.rating_count %}
                    {{ product.average_rating|floatformat:1 }}
                  {% else %}
                    New
                  {% endif %}
                </span>
              </div>
            </div>
            <div class="store-actions">
              <a href="{% url 'product' product.id %}" class="btn-details">
                View Details
                <i class="fas fa-arrow-right"></i>
              </a>
              <button data-product="{{product.id}}" data-action="add" class="icon-btn cart-btn update-cart" title="Add to cart">
                <i class="fas fa-cart-plus"></i>
              </button>
              {% csrf_token %}
              <span class="product_data addToWishlist icon-btn wish-btn" title="Add to wishlist">
                <i class="fas fa-heart"></i>
                <input type="hidden" value="{{product.id}}" class="prod_id">
              </span>
            </div>
          </div>
        </div>
        {% empty %}
        <div class="empty-state">
          <i class="fas fa-books"></i>
          <h4>No books available right now</h4>
          <p>New titles will appear here as soon as they are added to the store.</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

