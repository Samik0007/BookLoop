<script>
(function () {
    'use strict';

    var section      = document.getElementById('btmgya-section');
    var grid         = document.getElementById('btmgya-grid');
    var headingEl    = section ? section.querySelector('.btmgya-heading') : null;
    var subEl        = section ? section.querySelector('.btmgya-sub') : null;

    var TITLES = {
        ai_success:      '\u2726 Books That Might Get Your Attention',
        trending:        'Trending Books',
        fallback:        'Trending Books',
        unauthenticated: 'Trending Books',
        error:           'Trending Books'
    };
    var SUBS = {
        ai_success:      'Personalised picks powered by AI \u2014 based on what you\'ve bought, saved & carted',
        trending:        'Popular books on BookLoop right now',
        fallback:        'Popular books picked just for you',
        unauthenticated: 'Popular books on BookLoop right now',
        error:           'Popular books on BookLoop right now'
    };

    function setHeading(status) {
        if (headingEl) { headingEl.textContent = TITLES[status] || TITLES.fallback; }
        if (subEl)     { subEl.textContent     = SUBS[status]  || SUBS.fallback;   }
    }

    function buildCard(book) {
        var imgHtml = book.image_url
            ? '<img src="' + escHtml(book.image_url) + '" alt="' + escHtml(book.title)
              + '" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'block\';">'
              + '<span class="btmgya-placeholder" style="display:none">\uD83D\uDCD6</span>'
            : '<span class="btmgya-placeholder">\uD83D\uDCD6</span>';

        var origPrice = parseFloat(book.price) || 0;
        var discPrice = parseFloat(book.discounted_price) || 0;
        var priceHtml;
        if (discPrice > 0 && discPrice < origPrice) {
            priceHtml = '<span class="btmgya-price">Rs. ' + discPrice.toFixed(0) + '</span>'
                      + '<span class="btmgya-price-orig">Rs. ' + origPrice.toFixed(0) + '</span>';
        } else {
            priceHtml = '<span class="btmgya-price">Rs. ' + origPrice.toFixed(0) + '</span>';
        }

        return '<div class="btmgya-card">'
            + '<div class="btmgya-card-img-wrap">' + imgHtml + '</div>'
            + '<div class="btmgya-card-body">'
            + '<span class="btmgya-badge">' + escHtml(book.genre || 'General') + '</span>'
            + '<h5 class="btmgya-title">' + escHtml(book.title) + '</h5>'
            + '<div class="btmgya-author">by ' + escHtml(book.author) + '</div>'
            + (book.reason ? '<div class="btmgya-reason">' + escHtml(book.reason) + '</div>' : '')
            + '<div class="btmgya-price-row">' + priceHtml + '</div>'
            + '<a class="btmgya-btn" href="' + escHtml(book.product_url) + '">View Book &rarr;</a>'
            + '</div>'
            + '</div>';
    }

    function renderCards(recs) {
        var html = '';
        for (var i = 0; i < recs.length; i++) { html += buildCard(recs[i]); }
        grid.innerHTML = html || '<p style="color:var(--muted);padding:20px">No books available right now.</p>';
    }

    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    var FETCH_TIMEOUT_MS = 40000;  // 40 s — Groq server timeout is 30 s; add buffer

    function fetchWithTimeout(url, ms) {
        var controller = (typeof AbortController !== 'undefined') ? new AbortController() : null;
        var timer = null;
        var promise = fetch(url, {
            method: 'GET',
            credentials: 'same-origin',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            signal: controller ? controller.signal : undefined
        }).then(function (res) {
            clearTimeout(timer);
            return res;
        });
        if (controller) {
            timer = setTimeout(function () { controller.abort(); }, ms);
        }
        return promise;
    }

    function showError() {
        if (grid) {
            grid.innerHTML =
                '<div style="grid-column:1/-1;text-align:center;padding:40px 20px;color:var(--muted);">' +
                '<p style="font-size:0.95rem;margin-bottom:0;">Couldn\'t load recommendations right now.</p>' +
                '<button onclick="window.btmgyaRetry()" style="display:inline-block;margin-top:14px;padding:8px 22px;border:1.5px solid var(--accent);color:var(--accent);border-radius:10px;font-weight:600;background:transparent;cursor:pointer;">&#8635; Try Again</button>' +
                '</div>';
        }
        setHeading('error');
    }

    document.addEventListener('DOMContentLoaded', function () {
        var CACHE_KEY    = 'btmgya_recs';
        var REFRESH_FLAG = 'btmgya_needs_refresh';
        var CACHE_TTL_MS = 4 * 60 * 60 * 1000;     // 4 h  — serve cached AI result
        var IS_LOGGED_IN = {% if request.user.is_authenticated %}true{% else %}false{% endif %};

        // ── Render a server response onto the page ────────────────────────────
        function applyData(data, skipCache) {
            var status = data.status || 'trending';
            var books  = data.recommendations || [];

            if (!books.length) {
                if (grid) {
                    grid.innerHTML =
                        '<div style="grid-column:1/-1;text-align:center;padding:40px 20px;color:var(--muted);">' +
                        '<p style="font-size:0.95rem;margin-bottom:0;">Add books to your cart or wishlist to get personalised picks.</p>' +
                        '<a href="/store/" style="display:inline-block;margin-top:14px;padding:8px 22px;background:var(--accent);color:#fff;border-radius:10px;text-decoration:none;font-weight:600;">Browse Books</a>' +
                        '</div>';
                }
                setHeading('trending');
                return;
            }

            renderCards(books);
            setHeading(status);

            var s     = data.source_count || {};
            var parts = [];
            if (s.purchased) parts.push(s.purchased + ' purchase' + (s.purchased > 1 ? 's' : ''));
            if (s.cart)      parts.push(s.cart + ' cart item'     + (s.cart > 1 ? 's' : ''));
            if (s.wishlist)  parts.push(s.wishlist + ' wishlist item' + (s.wishlist > 1 ? 's' : ''));
            if (subEl && parts.length) {
                subEl.textContent = 'Based on your ' + parts.join(', ');
            } else if (subEl && status !== 'ai_success') {
                subEl.textContent = 'Trending picks popular with other readers';
            }

            // Cache AI results so plain navigation never re-hits Groq.
            // cachedAt lets us expire stale caches after 4 hours even if
            // the user hasn't added to cart / wishlist / purchased.
            if (status === 'ai_success' && !skipCache) {
                try {
                    sessionStorage.setItem(CACHE_KEY, JSON.stringify({
                        recommendations: books,
                        source_count: s,
                        cachedAt: Date.now()
                    }));
                } catch(e) {}
            }
        }

        // ── Stage 1: fast trending books (always shown first) ─────────────────
        function fetchTrending() {
            fetch('/recommendations/api/trending/', {
                method: 'GET',
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function(res) { return res.ok ? res.json() : null; })
            .then(function(data) {
                if (data) applyData(data, true); // show trending, don't cache
            })
            .catch(function() {}); // silent — stage 2 will overwrite anyway
        }

        // ── Stage 2: AI recommendations (silently replaces trending when ready) ─
        // forceRefresh=true appends ?refresh=1 to bypass the server-side cache
        // (used after cart add / wishlist / purchase actions).
        function fetchAI(forceRefresh) {
            var url = '/recommendations/api/homepage/' + (forceRefresh ? '?refresh=1' : '');
            fetch(url, {
                method: 'GET',
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function(res) { return res.ok ? res.json() : null; })
            .then(function(data) {
                if (data && data.status === 'ai_success') {
                    applyData(data);   // client-side cache written inside applyData
                }
                // If Groq fails, trending results from stage 1 remain visible.
                // Server-side cache means the next page load will retry cleanly.
            })
            .catch(function() {
                // Network error — trending results stay visible, no retry blocker set.
            });
        }

        // ── Full refresh (cart / wishlist / purchase action happened) ─────────
        function fetchRecommendations() {
            // Show skeleton while waiting
            var skels = '';
            for (var i = 0; i < 8; i++) {
                skels += '<div class="btmgya-skeleton"><div class="btmgya-sk-img"></div><div class="btmgya-sk-body"><div class="btmgya-sk-line short"></div><div class="btmgya-sk-line long"></div><div class="btmgya-sk-line medium"></div><div class="btmgya-sk-line short"></div><div class="btmgya-sk-btn"></div></div></div>';
            }
            if (grid) grid.innerHTML = skels;
            fetchTrending();                       // show trending immediately
            if (IS_LOGGED_IN) fetchAI(true);   // bypass server cache — user action happened
        }
        window.btmgyaRetry = fetchRecommendations;

        // ── Decide: serve cache, or do two-stage load ─────────────────────────
        var needsRefresh = false;
        try { needsRefresh = !!sessionStorage.getItem(REFRESH_FLAG); } catch(e) {}

        if (needsRefresh) {
            // Cart add / wishlist / purchase — force a completely fresh AI fetch
            try { sessionStorage.removeItem(REFRESH_FLAG); } catch(e) {}
            try { sessionStorage.removeItem(CACHE_KEY);    } catch(e) {}
            fetchRecommendations();
        } else {
            // Serve AI result from cache if available and fresh
            var servedFromCache = false;
            try {
                var cached = sessionStorage.getItem(CACHE_KEY);
                if (cached) {
                    var cachedData = JSON.parse(cached);
                    var cacheAge   = cachedData.cachedAt ? (Date.now() - cachedData.cachedAt) : Infinity;
                    if (cacheAge > CACHE_TTL_MS) {
                        // Expired — discard, fall through to fresh load
                        sessionStorage.removeItem(CACHE_KEY);
                    } else {
                        renderCards(cachedData.recommendations);
                        setHeading('ai_success');
                        var cs = cachedData.source_count || {};
                        var cp = [];
                        if (cs.purchased) cp.push(cs.purchased + ' purchase' + (cs.purchased > 1 ? 's' : ''));
                        if (cs.cart)      cp.push(cs.cart + ' cart item'     + (cs.cart > 1 ? 's' : ''));
                        if (cs.wishlist)  cp.push(cs.wishlist + ' wishlist item' + (cs.wishlist > 1 ? 's' : ''));
                        if (subEl && cp.length) subEl.textContent = 'Based on your ' + cp.join(', ');
                        servedFromCache = true;
                    }
                }
            } catch(e) {}

            if (!servedFromCache) {
                fetchTrending();                        // always show something fast
                if (IS_LOGGED_IN) fetchAI(false);   // server cache handles Groq throttling
            }
        }

        // ── Wishlist add while already on the homepage ────────────────────────
