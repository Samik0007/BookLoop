                    {% if form.image.errors %}<div class="field-error">{% for e in form.image.errors %}{{ e }}{% endfor %}</div>{% endif %}
                  </div>

                  <div class="col-12">
                    <label for="{{ form.description.id_for_label }}" class="form-label">
                      Description <span class="text-muted fw-normal">(optional)</span>
                    </label>
                    {{ form.description }}
                    {% if form.description.help_text %}<div class="field-hint">{{ form.description.help_text }}</div>{% endif %}
                    {% if form.description.errors %}<div class="field-error">{% for e in form.description.errors %}{{ e }}{% endfor %}</div>{% endif %}
                  </div>

                  <div class="col-12">
                    <label for="{{ form.swap_preference.id_for_label }}" class="form-label">
                      Books Wanted in Exchange {% if form.swap_preference.field.required %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    {{ form.swap_preference }}
                    {% if form.swap_preference.help_text %}<div class="field-hint">{{ form.swap_preference.help_text }}</div>{% endif %}
                    {% if form.swap_preference.errors %}<div class="field-error">{% for e in form.swap_preference.errors %}{{ e }}{% endfor %}</div>{% endif %}
                  </div>

                </div>
              </div>

              <!-- ── Section 3: Contact & Location ── -->
              <div class="swap-section-gap">
                <div class="swap-section-head">
                  <div class="section-icon"><i class="fas fa-map-marker-alt"></i></div>
                  <h6>Contact &amp; Location</h6>
                </div>
                <div class="row g-3">

                  <div class="col-md-6">
                    <label for="{{ form.location.id_for_label }}" class="form-label">
                      Pickup Location {% if form.location.field.required %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    {{ form.location }}
                    {% if form.location.help_text %}<div class="field-hint">{{ form.location.help_text }}</div>{% endif %}
                    {% if form.location.errors %}<div class="field-error">{% for e in form.location.errors %}{{ e }}{% endfor %}</div>{% endif %}
                  </div>

                  <div class="col-md-6">
                    <label for="{{ form.contact_email.id_for_label }}" class="form-label">
                      Contact Email {% if form.contact_email.field.required %}<span class="text-danger">*</span>{% endif %}
