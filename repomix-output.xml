<file path="templates/cart.html">
{% load static %}

{% include 'components/base/base-top.html' %}
{% include 'components/header/header.html' %}

<style>
:root {
  --bw-ink: #0b1f2a;
  --bw-muted: #52616b;
  --bw-accent: #1f8a70;
  --bw-accent-2: #f28f3b;
}

.cart-hero {
  padding: 30px 0 20px;
}

.cart-title {
  font-family: 'Merriweather', serif;
  font-size: 28px;
  margin-bottom: 6px;
}

.cart-summary {
  background: #ffffff;
  border-radius: 18px;
  padding: 18px;
  border: 1px solid #efe8da;
  box-shadow: 0 10px 25px rgba(27, 27, 31, 0.08);
}

.cart-list {
  margin-top: 20px;
  background: #ffffff;
  border-radius: 18px;
  border: 1px solid #efe8da;
  box-shadow: 0 10px 25px rgba(27, 27, 31, 0.08);
  padding: 18px;
}

.cart-row {
  display: grid;
  grid-template-columns: 100px 1.5fr 1fr 1fr 1fr 200px;
  gap: 14px;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0ece4;
}

.cart-row:last-child {
  border-bottom: none;
}

.cart-thumb {
  width: 90px;
  height: 90px;
  object-fit: cover;
  border-radius: 12px;
}

.qty-controls {
  display: flex;
  align-items: center;
  gap: 8px;
}

.qty-btn {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  border: 1px solid #e6e1d7;
  background: #fff;
  color: var(--bw-ink);
}

@media (max-width: 991px) {
  .cart-row {
    grid-template-columns: 90px 1fr;
    grid-template-areas:
      "image title"
      "price qty"
      "total action";
  }

  .cart-row .cart-image { grid-area: image; }
  .cart-row .cart-title { grid-area: title; }
  .cart-row .cart-price { grid-area: price; }
  .cart-row .cart-qty { grid-area: qty; }
  .cart-row .cart-total { grid-area: total; }
  .cart-row .cart-action { grid-area: action; }
}

.btn-buy-now {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  background: var(--bw-accent);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.15s;
  white-space: nowrap;
}
.btn-buy-now:hover { background: #176f58; color: #fff; }

.btn-save-wish {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  background: #fff;
  color: var(--bw-ink);
  border: 1.5px solid #e6e1d7;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
  white-space: nowrap;
}
.btn-save-wish:hover { border-color: #e11d48; color: #e11d48; }
.btn-save-wish.saved { border-color: #e11d48; color: #e11d48; }

.cart-action-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
</style>

<section class="cart-hero">
  <div class="container">
    <div class="cart-title">Your Cart</div>
    <p class="text-muted">Review your items and proceed to checkout.</p>

    <div class="cart-summary d-flex flex-wrap align-items-center justify-content-between">
      <div>
        <strong>Items:</strong> {{ order.get_cart_items }}
      </div>
      <div>
        <strong>Total:</strong> Rs. {{ order.get_cart_total|floatformat:2 }}
      </div>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="{% url 'store' %}">Continue Shopping</a>
        <a class="btn btn-success" href="{% url 'checkout' %}">Checkout</a>
      </div>
    </div>

    <div class="cart-list">
      <div class="cart-row" style="font-weight:700; color: var(--bw-muted);">
        <div>Image</div>
        <div>Item</div>
        <div>Price</div>
        <div>Quantity</div>
        <div>Total</div>
        <div>Action</div>
      </div>

      {% for item in items %}
      <div class="cart-row">
        <div class="cart-image">
          <a href="{% url 'product' item.Book_name.id %}">
            <img class="cart-thumb" src="{{ item.Book_name.imageURL }}" alt="{{ item.Book_name.Book_name }}">
          </a>
        </div>
        <div class="cart-title">{{ item.Book_name.Book_name }}</div>
        <div class="cart-price">Rs. {{ item.Book_name.discounted_price|floatformat:2 }}</div>
        <div class="cart-qty">
          <div class="qty-controls">
            <button data-product="{{ item.Book_name.id }}" data-action="remove" class="qty-btn update-cart">-</button>
            <strong>{{ item.quantity }}</strong>
            {% if item.Book_name.quantity >= item.quantity %}
              <button data-product="{{ item.Book_name.id }}" data-action="add" class="qty-btn update-cart">+</button>
            {% else %}
              <button class="qty-btn" disabled>+</button>
            {% endif %}
          </div>
        </div>
        <div class="cart-total">Rs. {{ item.get_total }}</div>
        <div class="cart-action">
          <div class="cart-action-group">

            <a href="{% url 'checkout' %}?buy_now={{ item.Book_name.id }}" class="btn-buy-now">
              <i class="fa fa-bolt"></i> Buy Now
            </a>

            <button
              class="btn-save-wish wish-btn"
              data-product-id="{{ item.Book_name.id }}"
              {% if item.Book_name in wishlist_products %}data-saved="true"{% endif %}>
              <i class="fa fa-heart"></i>
              <span>{% if item.Book_name in wishlist_products %}Saved{% else %}Wishlist{% endif %}</span>
            </button>

            <form action="{% url 'remove_cart' item.Book_name.id %}" method="POST" class="remove-form">
              {% csrf_token %}
              <button type="button" class="btn btn-danger btn-sm w-100 remove-btn"
                data-name="{{ item.Book_name.Book_name|escapejs }}">
                Remove
              </button>
            </form>

          </div>
        </div>
      </div>
      {% empty %}
      <p>No items in cart.</p>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── Remove-from-cart confirm dialog ─────────────────────────────────── -->
