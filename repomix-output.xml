<file path="templates/index.html">
{% load static %}

{% include 'components/base/base-top.html' %}

<!-- bootstrap css -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-eOJMYsd53ii+scO/bJGFsiCZc+5NDVN2yr8+0RDqr0Ql0h+rP48ckxlpbzKgwra6" crossorigin="anonymous">

<!-- icon css -->
<link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.3/css/all.css"
    integrity="sha384-SZXxX4whJ79/gErwcOYf+zWLeJdY/qpuqC4cAa9rOGUstPomtqpuNWT9wdPEn2fk" crossorigin="anonymous">

<!-- fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

{% include 'components/header/header.html' %}

<style>
:root {
    --ink: #0b1f2a;
    --muted: #52616b;
    --accent: #1f8a70;
    --accent-2: #f28f3b;
    --paper: #f7f3eb;
    --cream: #f3e7d3;
    --shadow: 0 18px 45px rgba(11, 31, 42, 0.12);
}

body {
    font-family: 'Work Sans', sans-serif;
    color: var(--ink);
    background: radial-gradient(circle at 10% 5%, #f7f3eb 0%, #ffffff 35%, #f1f6f4 100%);
}

h1, h2, h3 {
    font-family: 'Merriweather', serif;
}

.section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
}

.section-title h2 {
    font-size: 28px;
    margin: 0;
}

.section-title p {
    margin: 0;
    color: var(--muted);
}

.hero {
    position: relative;
    padding: 70px 0 50px;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    inset: -50px -80px auto auto;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(242, 143, 59, 0.25), rgba(242, 143, 59, 0));
    border-radius: 50%;
}

.hero::after {
    content: '';
    position: absolute;
    inset: auto auto -70px -50px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(31, 138, 112, 0.2), rgba(31, 138, 112, 0));
    border-radius: 50%;
}

.hero-card {
    background: linear-gradient(135deg, #ffffff 0%, #f6f1e7 100%);
    border-radius: 28px;
    padding: 40px;
    box-shadow: var(--shadow);
    position: relative;
    z-index: 1;
}

.hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: #e6f3ef;
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
}

.hero h1 {
    font-size: 40px;
    margin: 18px 0 12px;
}

.hero p {
    color: var(--muted);
    font-size: 16px;
}

.hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
}

.btn-primary-custom {
    background: var(--accent);
    border: none;
    color: #fff;
    padding: 12px 22px;
    border-radius: 12px;
    font-weight: 600;
}

.btn-outline-custom {
    border: 2px solid var(--accent);
    color: var(--accent);
    padding: 10px 20px;
    border-radius: 12px;
    font-weight: 600;
    background: transparent;
}

.hero-stack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
}

.hero-cover {
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 16px 35px rgba(0, 0, 0, 0.18);
    transform: rotate(-2deg);
}

.hero-cover:nth-child(2) {
    transform: rotate(3deg) translateY(10px);
}

.hero-cover img {
    width: 100%;
    height: 260px;
    object-fit: cover;
}

.feature-grid {
    margin-top: 30px;
}

.feature-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #f2ece0;
    box-shadow: 0 10px 30px rgba(27, 27, 31, 0.08);
    height: 100%;
}

.feature-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f4ff;
    color: #3943d0;
    font-size: 20px;
    margin-bottom: 12px;
}

.feature-card h5 {
    font-size: 18px;
    margin-bottom: 8px;
}

.feature-card p {
    color: var(--muted);
    font-size: 14px;
    margin: 0;
}

.panel {
    background: var(--paper);
    border-radius: 26px;
    padding: 28px;
    box-shadow: var(--shadow);
    margin-bottom: 40px;
}

.book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
}

.book-card {
    border-radius: 18px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid #f2ece0;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.book-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 35px rgba(27, 27, 31, 0.12);
}

/* book-cover-img: fixed aspect-ratio box so every card image is the same height */
.book-cover-img {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: contain;
    background: #f0eee9;          /* soft warm neutral — shows full cover without cropping */
}

.book-body {
    padding: 16px;
    flex: 1;
}

.book-body h5 {
    font-size: 16px;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.book-body p {
    color: var(--muted);
    margin: 0 0 10px;
    font-size: 13px;
}

.book-price {
    color: var(--accent);
    font-weight: 700;
    font-size: 16px;
}

.book-actions {
    padding: 0 16px 18px;
    margin-top: auto;  /* push button to bottom of every card in the row */
}

.book-actions a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    padding: 8px 16px;
    border-radius: 10px;
}

.btn-browse-more {
    display: inline-block;
    background-color: #1f8a70;
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 14px 48px;
    border-radius: 50px;
    text-decoration: none;
    letter-spacing: 0.4px;
    box-shadow: 0 4px 18px rgba(31,138,112,0.22);
    transition: background-color 0.22s ease, box-shadow 0.22s ease, transform 0.15s ease;
}
.btn-browse-more:hover {
    background-color: #166a56;
    box-shadow: 0 6px 24px rgba(31,138,112,0.32);
    transform: translateY(-2px);
    color: #fff;
}

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
}

.gallery-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    min-height: 200px;
    color: #fff;
}

.gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.75);
}

.gallery-card h4 {
    position: absolute;
    bottom: 16px;
    left: 16px;
    margin: 0;
    font-size: 20px;
    font-weight: 700;
}

.reco-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 22px;
}

.reco-card {
    border-radius: 18px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid #f2ece0;
    box-shadow: 0 8px 25px rgba(27, 27, 31, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.reco-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 35px rgba(27, 27, 31, 0.12);
}

.reco-image img {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: contain;
    background: #f0eee9;
}

.reco-body {
    padding: 16px;
}

.reco-body h5 {
    font-size: 16px;
    margin-bottom: 6px;
}

.reco-meta {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 10px;
}

.reco-price {
    color: var(--accent);
    font-weight: 700;
    font-size: 18px;
}

.reco-actions a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-weight: 600;
    color: var(--accent);
    border: 2px solid var(--accent);
    padding: 8px 14px;
    border-radius: 10px;
}

@media (max-width: 991px) {
    .hero {
        padding-top: 40px;
    }

    .hero h1 {
        font-size: 32px;
    }

    .hero-cover img {
        height: 220px;
    }
}

@media (max-width: 767px) {
    .section-title {
        flex-wrap: wrap;
        gap: 10px;
    }

    .section-title h2 {
        font-size: 22px;
    }

    .hero {
        padding: 30px 0 20px;
    }

    .hero-card {
        padding: 24px 18px;
    }

    .hero h1 {
        font-size: 26px;
        margin: 12px 0 10px;
    }

    .hero p {
        font-size: 14px;
    }

    .hero-stack {
        gap: 12px;
    }

    .hero-cover img {
        height: 180px;
    }

    .hero-actions {
        gap: 8px;
    }

    .panel {
        padding: 20px 14px;
        border-radius: 18px;
    }

    .gallery {
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .gallery-card {
        min-height: 150px;
    }

    .gallery-card h4 {
        font-size: 16px;
        bottom: 12px;
        left: 12px;
    }

    .feature-card {
        padding: 16px;
    }

    .btmgya-heading {
        font-size: 1.3rem !important;
    }

    .btn-browse-more {
        padding: 12px 32px;
        font-size: 0.9rem;
    }
}

@media (max-width: 480px) {
    .hero h1 {
        font-size: 22px;
    }

    .hero-stack {
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .hero-cover {
        transform: none !important;
    }

    .hero-cover img {
        height: 200px;
    }

    .hero-actions {
        flex-direction: column;
        align-items: stretch;
    }

    .btn-primary-custom,
    .btn-outline-custom {
        text-align: center;
    }

    .gallery {
        grid-template-columns: 1fr;
    }

    .book-body h5 {
        font-size: 14px;
    }

    .book-price {
        font-size: 14px;
    }

    .book-actions a {
        font-size: 13px;
        padding: 7px 12px;
    }

    .btn-browse-more {
        padding: 11px 24px;
        font-size: 0.85rem;
        display: block;
        text-align: center;
    }

    .feature-grid .col-md-4 {
        margin-bottom: 8px;
    }
}
</style>

