      text-align:center; box-shadow:0 24px 60px rgba(0,0,0,0.3);
      transform:scale(0.85); opacity:0;
      transition:transform 0.35s cubic-bezier(.34,1.56,.64,1), opacity 0.3s ease;
      position:relative;" id="bw-success-card">
    <!-- Animated checkmark -->
    <div style="
        width:80px; height:80px; border-radius:50%;
        background:linear-gradient(135deg,#1f8a70,#22a885);
        display:flex; align-items:center; justify-content:center;
        margin:0 auto 24px; font-size:36px; box-shadow:0 8px 28px rgba(31,138,112,0.35);">
      ✓
    </div>
    <h2 style="font-family:'Merriweather',serif;font-size:1.5rem;color:#0b1f2a;margin-bottom:10px;">
      Order Placed Successfully!
    </h2>
    <p style="color:#52616b;font-size:0.95rem;line-height:1.6;margin-bottom:8px;">
      Thank you for shopping with <strong style="color:#1f8a70;">Book Loop</strong>!<br>
      We've received your order and will process it shortly.
    </p>
    <p style="color:#aaa;font-size:0.82rem;margin-bottom:28px;">
      A confirmation email has been sent to you.
    </p>
    <!-- Progress bar -->
    <div style="height:4px;background:#e8f4f1;border-radius:4px;overflow:hidden;margin-bottom:28px;">
      <div id="bw-progress-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#1f8a70,#f28f3b);border-radius:4px;transition:width 3s linear;"></div>
    </div>
    <a href="{% url 'order' %}" style="
        display:inline-block;padding:12px 32px;
        background:linear-gradient(135deg,#1f8a70,#22a885);
        color:#fff;border-radius:12px;font-weight:700;text-decoration:none;
        font-size:0.95rem;box-shadow:0 4px 16px rgba(31,138,112,0.3);
        transition:transform 0.2s,box-shadow 0.2s;"
       onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(31,138,112,0.45)'"
       onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 16px rgba(31,138,112,0.3)'">
      View My Orders
    </a>
  </div>
</div>

<script>
    var shipping = '{{Order.shipping}}'
    var total = '{% if is_buy_now %}{{ buy_now_total }}{% else %}{{ order.get_cart_total }}{% endif %}'
    var buy_now_product_id = '{{ buy_now_product_id|default:"" }}'
    var form = document.getElementById('form')

    form.addEventListener('submit', function(e){
        e.preventDefault()
        document.getElementById('form-button').classList.add('hidden');
        document.getElementById('payment-info').classList.remove('hidden');
    })

    // ── Helpers ───────────────────────────────────────────────────────────────
    function collectShipping() {
        if (shipping === 'False') return {};
        return {
            address: form.address.value,
            city:    form.city.value,
            ward_no: form.ward_no.value,
            email:   form.email.value,
            phone:   form.phone.value,
        };
    }

    // ── Cash on Delivery ──────────────────────────────────────────────────────
    document.getElementById('make-payment').addEventListener('click', function(e) {
        e.preventDefault();
        if (!confirm('Are you sure you want to place this order?')) return;

        var payload = { form: { total }, shipping: collectShipping() };
        if (buy_now_product_id) payload.buy_now_product_id = buy_now_product_id;

        fetch('/process_order/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRFToken': csrftoken },
            body: JSON.stringify(payload),
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
            if (data.error) {
                showPaymentError(data.error);
            } else {
                showOrderConfirmation();
            }
        });
    });

    function showPaymentError(msg) {
        var box = document.getElementById('khalti-error');
        box.textContent   = msg;
        box.style.display = 'block';
        box.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // ── Khalti ────────────────────────────────────────────────────────────────
    document.getElementById('khalti-payment').addEventListener('click', function(e) {
        e.preventDefault();

        var btn      = this;
        var loading  = document.getElementById('khalti-loading');
        var errorBox = document.getElementById('khalti-error');

        btn.disabled           = true;
        loading.style.display  = 'block';
        errorBox.style.display = 'none';

        var payload = { total: total, shipping: collectShipping() };
        if (buy_now_product_id) payload.buy_now_product_id = buy_now_product_id;

        fetch('/khalti/initiate/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRFToken': csrftoken },
            body: JSON.stringify(payload),
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
            if (data.payment_url) {
                window.location.href = data.payment_url;
            } else {
                throw new Error(data.error || 'Could not start Khalti payment.');
            }
        })
        .catch(function(err) {
            loading.style.display  = 'none';
            btn.disabled           = false;
            errorBox.textContent   = err.message || 'Payment initiation failed. Try again.';
            errorBox.style.display = 'block';
        });
    });

    // ── Success Modal ─────────────────────────────────────────────────────────
    function showOrderConfirmation() {
        // Mark recommendations stale — purchase changes what Groq should suggest
        try { sessionStorage.setItem('btmgya_needs_refresh', '1'); } catch(e) {}

        var overlay = document.getElementById('bw-success-overlay');
        var card    = document.getElementById('bw-success-card');
        var bar     = document.getElementById('bw-progress-bar');

        overlay.style.display = 'flex';
        // Trigger animation on next frame
        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                card.style.transform = 'scale(1)';
                card.style.opacity   = '1';
                bar.style.width      = '100%';
            });
        });

        // Auto-redirect after 3.2 s
        setTimeout(function() {
            window.location.href = "{% url 'order' %}";
        }, 3200);
    }
</script>


